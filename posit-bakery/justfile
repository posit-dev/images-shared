#!/usr/bin/env just --justfile

# Fallback to parent justfile(s)
set fallback

################
# Variables
CWD := justfile_directory()

################
# Default command, must be first in the file
[private]
_default:
    just --list --unsorted

################
# Setup commands

# Set up local dev environment
setup:
    just _setup-uv

[private]
_setup-uv:
    uv --version || just _python-executable uv

################
# Commands

# Install the posit-bakery python project
install:
    uv sync \
        --directory={{ CWD }}

alias package := build
# Build the posit-bakery python project
build:
    uv build \
        --directory={{ CWD }}

[private]
_pytest *ARGS:
    uv run pytest \
        -n auto \
        --dist loadgroup \
        --cov=posit_bakery \
        --cov-report=term-missing \
        {{ ARGS }} \
        {{ CWD }}/test/

# Note: Both sets of quotes are required
# Test the posit-bakery python project, skipping image build tests
test *ARGS:
    NO_COLOR="true" \
    just _pytest {{ ARGS }} -m "'not image_build'"

# Run all tests (including image builds; -n 4 limits parallel builds to avoid OOM)
test-all *ARGS:
    NO_COLOR="true" \
    just _pytest -n 4 {{ ARGS }}

# Regenerate API reference pages from package source using great-docs
docs-reference:
    uv run --group docs great-docs build --project-path {{ CWD }}
    rm -rf {{ CWD }}/docs/reference
    cp -r {{ CWD }}/great-docs/reference {{ CWD }}/docs/reference
    rm -rf {{ CWD }}/great-docs

# Preview the documentation site (run docs-reference first if reference/ is missing)
docs-preview:
    @test -d {{ CWD }}/docs/reference || just docs-reference
    cd {{ CWD }}/docs && quarto preview

# Render the documentation site
docs-render: docs-reference
    cd {{ CWD }}/docs && quarto render
