#!/usr/bin/env just --justfile

# Fallback to parent justfile(s)
set fallback

################
# Variables
CWD := justfile_directory()

################
# Default command, must be first in the file
[private]
_default:
    just --list --unsorted

################
# Setup commands

# Set up local dev environment
setup:
    just _setup-uv

[private]
_setup-uv:
    uv --version || just _python-executable uv

################
# Commands

# Install the posit-bakery python project
install:
    uv sync \
        --directory={{ CWD }}

alias package := build
# Build the posit-bakery python project
build:
    uv build \
        --directory={{ CWD }}

[private]
_pytest *ARGS:
    uv run pytest \
        -n auto \
        --dist loadgroup \
        --cov=posit_bakery \
        --cov-report=term-missing \
        {{ ARGS }} \
        {{ CWD }}/test/

# Note: Both sets of quotes are required
# Test the posit-bakery python project, skipping slow tests
test *ARGS:
    NO_COLOR="true" \
    just _pytest {{ ARGS }} -m "'not slow'"

# Run all tests
test-all *ARGS:
    NO_COLOR="true" \
    just _pytest {{ ARGS }}
