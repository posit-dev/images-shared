{
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "permissions": {
    "additionalDirectories": [
      "../images",
      "../images-examples",
      "../images-connect",
      "../images-package-manager",
      "../images-workbench",
      "../helm"
    ],
    "allow": [
      "Bash(bakery build:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git show:*)",
      "Bash(just test:*)",
      "Bash(ls:*)",
      "Bash(poetry run:*)",
      "Bash(python3:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  }
}
